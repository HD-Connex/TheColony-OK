# ─────────────────────────────────────────────────────────────
# The Colony OK — Mobile (Expo) Environment Variables
# Copy to .env.local and fill in. NEVER commit real secrets.
# For EAS builds, set these as EAS environment variables / secrets
# (eas env / EAS dashboard) — eas.json no longer hard-codes them.
# ─────────────────────────────────────────────────────────────

# Supabase (auth + database) — required for the app to boot
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Modern projects use sb_publishable_* for the public key; the app reads
# either EXPO_PUBLIC_SUPABASE_ANON_KEY or EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY

# Site / API base URL (used for deep links and web fallbacks)
EXPO_PUBLIC_SITE_URL=https://thecolonyok.com
