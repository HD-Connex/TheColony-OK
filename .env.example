# ─────────────────────────────────────────────────────────────
# The Colony OK — Environment Variables
# Copy to .env.local and fill in. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── Supabase (auth + database) — CORE for public reads ──
# Updated per Supabase Next.js SSR quickstart (new project).
# Modern projects use sb_publishable_* for the public/anon key.
# Code supports BOTH names for compatibility (ANON legacy or PUBLISHABLE).
NEXT_PUBLIC_SUPABASE_URL=https://jwqgirmxoksxhevjnnwm.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_Hj5zHMNOV-Ji3q4ufIJnrA_YIFxBUzK
# Legacy alias (set to same value for older code paths / parity):
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_Hj5zHMNOV-Ji3q4ufIJnrA_YIFxBUzK
# Service role (bypasses RLS) — required for admin APIs, crons, Stripe webhook sync, progress saves, tips, newsletter, etc.
# (lib/supabase.ts supabaseAdmin). Without it, privileged server ops 500/throw.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Add the service role key for admin operations

# Connection string (from Supabase dashboard - replace [YOUR-PASSWORD])
# Use for migrations / server-side pooled connections (scripts only, not runtime app)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.jwqgirmxoksxhevjnnwm.supabase.co:5432/postgres
# Direct (non-pooled) for migrations if needed
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.jwqgirmxoksxhevjnnwm.supabase.co:5432/postgres

# Site (core)
NEXT_PUBLIC_SITE_URL=https://thecolonyok.com
NEXT_PUBLIC_APP_NAME="The Colony"

# Direct (non-pooled) connection for migrations (optional):
# DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# 24/7 live stream (Mux HLS or Cloudflare Stream) — public, optional
NEXT_PUBLIC_247_HLS_URL=https://stream.mux.com/your-247-playback.m3u8
# Or use Mux playback ID (builds HLS URL automatically):
# NEXT_PUBLIC_MUX_247_PLAYBACK_ID=your-mux-playback-id
# NEXT_PUBLIC_247_MP4_URL=... (loop)
# NEXT_PUBLIC_247_YOUTUBE_URL=...

# ── Auth (Clerk) — optional; app uses Supabase auth (magic OTP + members table) ──
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# CLERK_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# ...

# ── Payments (Stripe) — optional (membership flows). Without = pricing/checkout 503 or disabled UI ──
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...   # (client-side not heavily used yet; server flows use secret)
# STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs for the membership tiers (create in Stripe dashboard). Any one enables "member".
# STRIPE_PRICE_SETTLER=price_...     # Settler  — $4.99/mo (founding)
# STRIPE_PRICE_PATRIOT=price_...     # Patriot  — $9.99/mo
# STRIPE_PRICE_FOUNDER=price_...     # Founder  — $19.99/mo
# (Legacy / alt names also honored: STRIPE_PRICE_MEMBER, STRIPE_PRICE_GIFT)

# ── Video (Mux) — optional for podcasts/live. Without = live/admin "Go Live", signed playback, webhooks degrade ──
# MUX_TOKEN_ID=...
# MUX_TOKEN_SECRET=...
# MUX_WEBHOOK_SECRET=...
# Signing key for secure (members-only) playback tokens:
# MUX_SIGNING_KEY_ID=...
# MUX_SIGNING_PRIVATE_KEY=LS0t... # base64 PEM

# ── AI (Vercel AI SDK / Whisper / embeddings) — optional ──
# ANTHROPIC_API_KEY=sk-ant-...     # faith-aligned summaries & clip generation
# OPENAI_API_KEY=sk-...            # embeddings + Whisper transcription (used by /api/jobs/transcribe + semantic-search)
# GROQ_API_KEY=...                 # preferred fast Whisper (whisper-large-v3) + chat fallbacks

# ── Jobs / Cron — optional ──
# Protects /api/cron/* and /api/jobs/* ; Vercel Cron sends this as a Bearer token.
# If unset: crons return 403 in production (safe), dev allows. Not required for basic site boot.
# CRON_SECRET=generate-a-long-random-string

# ── Admin / Service auth (server-to-server) — optional but recommended for machine callers ──
# Long random string. Used by lib/admin-auth.ts for requireServiceToken and
# internal admin APIs (moderate clips, transcribe, etc). Send as `Authorization: Bearer <token>`.
# If unset: requireServiceToken returns false (falls back to human admin role check where possible).
# ADMIN_SERVICE_TOKEN=superlongrandomstringforadminandservicesonly

# ── Email (Resend) — for transactional (welcome, receipts, acks, digest) — optional, best-effort ──
# Get key at https://resend.com . From domain should match your verified domain
# or use onboarding@resend.dev for testing.
# Without = emails are silent no-ops (logged).
# RESEND_API_KEY=re_...
# RESEND_FROM="The Colony OK <no-reply@thecolonyok.com>"

# ── Rate limiting (Upstash Redis REST) — optional, falls back to per-instance Map ──
# For production multi-region enforcement of /api/tips, contrib-apply, clips, etc.
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# ── Error tracking (Sentry) — optional but strongly recommended for prod ──
# NEXT_PUBLIC_SENTRY_DSN=https://...@....ingest.sentry.io/...   # browser + some server
# SENTRY_DSN=https://...@....ingest.sentry.io/...               # server/edge (secret)
# SENTRY_AUTH_TOKEN=...   # for source maps/releases in CI (optional)
# SENTRY_ORG=your-org
# SENTRY_PROJECT=thecolony-app

# ── Self-hosted video providers (future scaffold in lib/video.ts) — optional ──
# VIDEO_PROVIDER=mux|bunny|cloudflare
# BUNNY_STREAM_HOST=...
# CLOUDFLARE_STREAM_CODE=...

# ── Full list enforced at boot via lib/env.ts assertEnv() (called from instrumentation.ts) ──
# CORE_REQUIRED_IN_PRODUCTION (hard fail in prod, warn in dev — minimal for public content to render):
#   NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY (or PUBLISHABLE_KEY), NEXT_PUBLIC_SITE_URL
#
# FEATURE_RECOMMENDED (warn only; features degrade gracefully, never block basic boot in prod):
#   SUPABASE_SERVICE_ROLE_KEY, STRIPE_* (secret/webhook/prices), CRON_SECRET, ADMIN_SERVICE_TOKEN,
#   MUX_* (all), BLOB_READ_WRITE_TOKEN, RESEND_API_KEY, OPENAI/GROQ_API_KEY, UPSTASH_*, SENTRY_*,
#   and the various 247_/YT_ public overrides.
#
# Add any new *core* var to lib/env.ts CORE_REQUIRED_IN_PRODUCTION.
# Document feature vars here. Never commit real values.
# Use Vercel → Project → Environment Variables for prod/preview (separate from local .env.local).
# See lib/env.ts for the exact assert logic + graceful philosophy.
