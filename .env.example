# ─────────────────────────────────────────────────────────────
# The Colony OK — Environment Variables
# Copy to .env.local and fill in. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── Supabase (auth + database) ──
# Updated per Supabase Next.js SSR quickstart (new project)
NEXT_PUBLIC_SUPABASE_URL=https://jwqgirmxoksxhevjnnwm.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_Hj5zHMNOV-Ji3q4ufIJnrA_YIFxBUzK
# Legacy name for compatibility with existing code:
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_Hj5zHMNOV-Ji3q4ufIJnrA_YIFxBUzK
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Add the service role key for admin operations

# Connection string (from Supabase dashboard - replace [YOUR-PASSWORD])
# Use for migrations / server-side pooled connections
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.jwqgirmxoksxhevjnnwm.supabase.co:5432/postgres
# Direct (non-pooled) for migrations if needed
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.jwqgirmxoksxhevjnnwm.supabase.co:5432/postgres

# Site
NEXT_PUBLIC_SITE_URL=https://thecolonyok.com
NEXT_PUBLIC_APP_NAME="The Colony"

# Direct (non-pooled) connection for migrations (optional):
# DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# 24/7 live stream (Mux HLS or Cloudflare Stream)
NEXT_PUBLIC_247_HLS_URL=https://stream.mux.com/your-247-playback.m3u8
# Or use Mux playback ID (builds HLS URL automatically):
# NEXT_PUBLIC_MUX_247_PLAYBACK_ID=your-mux-playback-id

# ── Auth (Clerk) — optional; app uses Supabase auth ──
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# CLERK_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/welcome

# ── Payments (Stripe) — optional ──
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs for the three membership tiers (create in Stripe dashboard)
# STRIPE_PRICE_SETTLER=price_...     # Settler  — $4.99/mo (honors Colony OK founding price)
# STRIPE_PRICE_PATRIOT=price_...     # Patriot  — $9.99/mo
# STRIPE_PRICE_FOUNDER=price_...     # Founder  — $19.99/mo
# Contributor masthead tiers (future — apply flow is live, Stripe deferred)
# STRIPE_PRICE_CONTRIBUTOR=price_...   # $14.99/mo
# STRIPE_PRICE_FEATURED=price_...      # $49.99/mo
# STRIPE_PRICE_HEADLINER=price_...     # $99.99/mo

# ── Video (Mux) — optional ──
# MUX_TOKEN_ID=...
# MUX_TOKEN_SECRET=...
# MUX_WEBHOOK_SECRET=...
# Signing key for secure (members-only) playback tokens:
# MUX_SIGNING_KEY_ID=...
# MUX_SIGNING_PRIVATE_KEY=LS0t... # base64 PEM

# ── AI (Vercel AI SDK) — optional ──
# ANTHROPIC_API_KEY=sk-ant-...     # faith-aligned summaries & clip generation
# OPENAI_API_KEY=sk-...            # embeddings + Whisper transcription

# ── Jobs / Cron — optional ──
# Protects /api/cron/* and /api/jobs/* ; Vercel Cron sends this as a Bearer token.
# CRON_SECRET=generate-a-long-random-string

# ── Admin / Service auth (server-to-server) — optional but recommended ──
# Long random string. Used by lib/admin-auth.ts for requireServiceToken and
# internal admin APIs. Send as `Authorization: Bearer <token>`.
# ADMIN_SERVICE_TOKEN=superlongrandomstringforadminandservicesonly

# ── Email (Resend) — for transactional (welcome, receipts, acks) ──
# Get key at https://resend.com . From domain should match your verified domain
# or use onboarding@resend.dev for testing.
# RESEND_API_KEY=re_...
# RESEND_FROM="The Colony OK <no-reply@thecolonyok.com>"

# ── Rate limiting (Upstash Redis REST) — optional, falls back to per-instance Map ──
# For production multi-region enforcement of /api/tips, contrib-apply, etc.
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# ── Error tracking (Sentry) — optional but strongly recommended for prod ──
# NEXT_PUBLIC_SENTRY_DSN=https://...@....ingest.sentry.io/...   # browser + some server
# SENTRY_DSN=https://...@....ingest.sentry.io/...               # server/edge (secret)
# SENTRY_AUTH_TOKEN=...   # for source maps/releases in CI (optional, see vercel-cicd)
# SENTRY_ORG=your-org
# SENTRY_PROJECT=thecolony-app

# ── Full list enforced at boot via lib/env.ts assertEnv() (called from instrumentation.ts) ──
# REQUIRED_IN_PRODUCTION (hard fail in prod, warn in dev):
#   NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY,
#   STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, CRON_SECRET, NEXT_PUBLIC_SITE_URL
# RECOMMENDED (warn only in dev; features degrade):
#   STRIPE_PRICE_*, MUX_*, BLOB_READ_WRITE_TOKEN, RESEND_API_KEY, ADMIN_SERVICE_TOKEN,
#   SENTRY_DSN / NEXT_PUBLIC_SENTRY_DSN, UPSTASH_*
#
# Add any new required var to lib/env.ts REQUIRED_IN_PRODUCTION and document here.
# Never commit real values. Use Vercel → Project → Environment Variables for prod/preview.