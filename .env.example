# ─────────────────────────────────────────────────────────────
# The Colony OK — Environment Variables
# Copy to .env.local and fill in. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── Supabase (auth + database) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site
NEXT_PUBLIC_SITE_URL=https://thecolonyok.com
NEXT_PUBLIC_APP_NAME="The Colony"

# Direct (non-pooled) connection for migrations (optional):
# DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# 24/7 live stream (Mux HLS or Cloudflare Stream)
NEXT_PUBLIC_247_HLS_URL=https://stream.mux.com/your-247-playback.m3u8
# Or use Mux playback ID (builds HLS URL automatically):
# NEXT_PUBLIC_MUX_247_PLAYBACK_ID=your-mux-playback-id

# ── Auth (Clerk) — optional; app uses Supabase auth ──
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# CLERK_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/welcome

# ── Payments (Stripe) — optional ──
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs for the three membership tiers (create in Stripe dashboard)
# STRIPE_PRICE_SETTLER=price_...     # Settler  — $4.99/mo (honors Colony OK founding price)
# STRIPE_PRICE_PATRIOT=price_...     # Patriot  — $9.99/mo
# STRIPE_PRICE_FOUNDER=price_...     # Founder  — $19.99/mo

# ── Video (Mux) — optional ──
# MUX_TOKEN_ID=...
# MUX_TOKEN_SECRET=...
# MUX_WEBHOOK_SECRET=...
# Signing key for secure (members-only) playback tokens:
# MUX_SIGNING_KEY_ID=...
# MUX_SIGNING_PRIVATE_KEY=LS0t... # base64 PEM

# ── AI (Vercel AI SDK) — optional ──
# ANTHROPIC_API_KEY=sk-ant-...     # faith-aligned summaries & clip generation
# OPENAI_API_KEY=sk-...            # embeddings + Whisper transcription

# ── Jobs / Cron — optional ──
# Protects /api/cron/* and /api/jobs/* ; Vercel Cron sends this as a Bearer token.
# CRON_SECRET=generate-a-long-random-string